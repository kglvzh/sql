# Задание 2
import psycopg2
from psycopg2 import Error

connection = None
cursor = None

try:
    connection = psycopg2.connect(
        user="mgpu_ico_st_03",
        password="oVU3Ioe9",
        host="95.131.149.21",
        port="5432",
        database="bi_sql_data_student"  
    )
    cursor = connection.cursor()

    # Удаление схемы вместе со всеми таблицами
    cursor.execute("DROP SCHEMA IF EXISTS hr CASCADE;")
    print("Схема hr удалена")

    # Создание схемы заново
    cursor.execute("CREATE SCHEMA hr;")
    print("Схема hr создана")

    # Создание таблиц
    cursor.execute("""
        SET search_path TO hr;

        CREATE TABLE departments (
            department_id SERIAL PRIMARY KEY,
            name VARCHAR(100) NOT NULL,
            location VARCHAR(200)
        );

        CREATE TABLE position (
            position_id SERIAL PRIMARY KEY,
            title VARCHAR(100) NOT NULL,
            description TEXT
        );

        CREATE TABLE employees_hr (
            employee_id SERIAL PRIMARY KEY,
            first_name VARCHAR(50) NOT NULL,
            last_name VARCHAR(50) NOT NULL,
            hire_date DATE,
            email VARCHAR(100) UNIQUE,
            department_id INTEGER,
            position_id INTEGER,
            salary NUMERIC(10, 2)
        );

        CREATE TABLE employment (
            employment_id SERIAL PRIMARY KEY,
            employee_id INTEGER,
            department_id INTEGER,
            position_id INTEGER,
            salary NUMERIC(10, 2)
        );
    """)
    print("Таблицы успешно созданы")

    connection.commit()
    print("Все операции выполнены успешно")

except (Exception, Error) as error:
    print(f"Ошибка: {error}")
    if connection:
        connection.rollback()
        print("Изменения откачены")

finally:
    if connection:
        if cursor:
            cursor.close()
        connection.close()
        print("Соединение закрыто")

