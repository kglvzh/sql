# Задание 4
import psycopg2
from psycopg2 import Error

connection = None
cursor = None
schema_name = "hr"
table_name = "employees_hr"

try:
    connection = psycopg2.connect(
        user="mgpu_ico_st_03",
        password="oVU3Ioe9",
        host="95.131.149.21",
        port="5432",
        database="bi_sql_data_student"
    )
    cursor = connection.cursor()

    cursor.execute(f"SET search_path TO {schema_name};")

    select_query = f"SELECT * FROM {table_name};"
    cursor.execute(select_query)
    
    print(f"\nЗапрос: Список всех сотрудников")
    print("=" * 80)

    records = cursor.fetchall()
    if records:
        colnames = [desc[0] for desc in cursor.description]
        
        header = " | ".join([f"{name:^20}" for name in colnames])
        print(header)
        print("-" * len(header))
        
        for row in records:
            formatted_row = " | ".join([f"{str(val):^20}" if val is not None else f"{'NULL':^20}" for val in row])
            print(formatted_row)
        
        print(f"\nВсего записей: {len(records)}")
    else:
        print("Запрос не вернул записей.")
    
    print("=" * 80)

except (Exception, Error) as error:
    print(f"Ошибка при выполнении SELECT запроса к {schema_name}.{table_name}:", error)

finally:
    if connection:
        if cursor:
            cursor.close()
        connection.close()
        print(f"\nСоединение с PostgreSQL закрыто.")

# Задание 5
import psycopg2
from psycopg2 import Error

connection = None
cursor = None
schema_name = "hr"

try:
    connection = psycopg2.connect(
        user="mgpu_ico_st_03",
        password="oVU3Ioe9",
        host="95.131.149.21",
        port="5432",
        database="bi_sql_data_student"
    )
    cursor = connection.cursor()

    cursor.execute(f"SET search_path TO {schema_name};")

    # Запрос: получить информацию о сотрудниках с названиями отделов и должностей
    join_query = """
        SELECT 
            e.employee_id,
            e.first_name,
            e.last_name,
            e.email,
            d.name AS department_name,
            p.title AS position_title,
            e.salary
        FROM employees_hr e
        LEFT JOIN departments d ON e.department_id = d.department_id
        LEFT JOIN position p ON e.position_id = p.position_id;
    """
    cursor.execute(join_query)
    
    print(f"\nЗапрос: Информация о сотрудниках с отделами и должностями")
    print("=" * 100)

    records = cursor.fetchall()
    if records:
        colnames = [desc[0] for desc in cursor.description]
        
        header = " | ".join([f"{name:^20}" for name in colnames])
        print(header)
        print("-" * len(header))
        
        for row in records:
            formatted_row = " | ".join([f"{str(val):^20}" if val is not None else f"{'NULL':^20}" for val in row])
            print(formatted_row)
        
        print(f"\nВсего записей: {len(records)}")
    else:
        print("Запрос не вернул записей.")
    
    print("=" * 100)

except (Exception, Error) as error:
    print(f"Ошибка при выполнении JOIN запроса в схеме {schema_name}:", error)

finally:
    if connection:
        if cursor:
            cursor.close()
        connection.close()
        print(f"\nСоединение с PostgreSQL закрыто.")
